      "id": "a263a95f-bb40-476b-b610-a13a7e79e203",
      "name": "Has IPs to Scan?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        -2144,
        -32
      ]
    },
    {
      "parameters": {
        "command": "=IP=\"{{ $json.ip }}\"\necho \"Scanning: $IP\"\n\n# Step 1: nmap se port 443 check karo\nPORT_STATUS=$(nmap -sT -Pn -p 443 \"$IP\" 2>/dev/null | grep '443/tcp' | awk '{print $2}')\necho \"Port 443 status: $PORT_STATUS\"\n\n# Step 2: Port open hai toh curl se TLS nikalo\nif [ \"$PORT_STATUS\" = \"open\" ]; then\n  RESULT=$(curl -vI --connect-timeout 15 --max-time 20 \"https://$IP\" 2>&1)\n  \n  CONN_LINE=$(echo \"$RESULT\" | grep 'SSL connection using')\n  \n  if [ -n \"$CONN_LINE\" ]; then\n    TLS_VER=$(echo \"$CONN_LINE\" | grep -oE 'TLSv[0-9.]+')\n    CIPHER=$(echo \"$CONN_LINE\" | awk -F'/' '{print $2}' | xargs)\n    TLS=\"$TLS_VER / $CIPHER\"\n  elif echo \"$RESULT\" | grep -qE 'TLSv[0-9.]+'; then\n    TLS_VER=$(echo \"$RESULT\" | grep -oE 'TLSv[0-9.]+' | sort -u | tr '\\n' ',' | sed 's/,$//')\n    TLS=\"$TLS_VER (cert error - TLS active)\"\n  else\n    TLS=\"Port open but no TLS detected\"\n  fi\n\nelif [ \"$PORT_STATUS\" = \"filtered\" ]; then\n  TLS=\"Port 443 filtered (firewall)\"\n\nelif [ \"$PORT_STATUS\" = \"closed\" ]; then\n  TLS=\"Port 443 closed\"\n\nelse\n  TLS=\"Host unreachable\"\nfi\n\necho \"TLS_RESULT:$TLS\"\necho \"IP_SCANNED:$IP\""
      },
      "id": "5ce09376-c0cd-44b7-80bb-c922de99f565",
      "name": "Run TLS Scan",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        -1920,
        -112
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst stdout = item.json.stdout || '';\n\nconst tlsMatch = stdout.match(/TLS_RESULT:(.+)/);\nconst ipMatch = stdout.match(/IP_SCANNED:(.+)/);\n\nconst tls = tlsMatch ? tlsMatch[1].trim() : 'Scan failed';\nconst ip = ipMatch ? ipMatch[1].trim() : '';\nconst rowNumber = $('Filter Unscanned IPs').item.json.row_number;\n\nreturn [{\n  json: {\n    ip,\n    tls_versions: tls,\n    row_number: rowNumber\n  }\n}];"
      },
