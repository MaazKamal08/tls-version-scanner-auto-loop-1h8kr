    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst toScan = items.filter(item => {\n  const tls = item.json['TLS Versions'];\n  return !tls || \n         tls.toString().trim() === '' || \n         tls.toString().trim().toLowerCase() === 'empty';\n});\n\nconsole.log(`Total IPs: ${items.length}, To scan: ${toScan.length}`);\n\nif (toScan.length === 0) {\n  return [{ json: { skip: true, ip: '', row_number: 0, message: 'All IPs already have TLS data' } }];\n}\n\nreturn toScan.map(item => ({\n  json: {\n    skip: false,\n    ip: item.json['IPs'].toString().trim(),\n    row_number: item.json['row_number']\n  }\n}));"
      },
      "id": "97b63288-3ef1-4890-829d-d8017ecab2bf",
      "name": "Filter Unscanned IPs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2352,
        -32
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
